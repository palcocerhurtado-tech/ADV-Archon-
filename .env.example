# ─── Motor LLM ────────────────────────────────────────────────────────────────
# URL base de Ollama (por defecto: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Modelo a usar. Ejemplos: llama3, mistral, llama3.1, gemma2, phi3
# Para ver tus modelos disponibles: ollama list
OLLAMA_MODEL=llama3

# ─── Memoria vectorial ────────────────────────────────────────────────────────
# Dónde guardar la base de datos ChromaDB con tus archivos indexados
MEMORY_PATH=~/.adv_archon/memory

# ─── Plugins ──────────────────────────────────────────────────────────────────
# Directorio donde Archon busca plugins personalizados (.py)
PLUGINS_PATH=~/.adv_archon/plugins

# ─── Indexación automática al arrancar ───────────────────────────────────────
# Pon "true" para indexar el directorio indicado al iniciar (puede ser lento)
INDEX_ON_START=false
INDEX_DIRECTORY=~
